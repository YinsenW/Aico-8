{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/semantic-vector-set-v1.schema.json",
  "title": "Aico 8 semantic vector set v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assets"],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "idArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    }
  },
  "properties": {
    "schemaVersion": { "const": "aico8.semantic-vector-set.v1" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourcePath", "sourceSha256", "sourceBytes", "recipeSha256", "viewBox", "origin", "requiredLayerIds", "elementIds"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "sourcePath": { "type": "string", "pattern": "^web-overlay/vector-assets/[a-z0-9][a-z0-9._-]*\\.svg$" },
          "sourceSha256": { "$ref": "#/$defs/sha256" },
          "sourceBytes": { "type": "integer", "minimum": 1 },
          "recipeSha256": { "$ref": "#/$defs/sha256" },
          "viewBox": {
            "type": "array", "minItems": 4, "maxItems": 4,
            "prefixItems": [
              { "const": 0 }, { "const": 0 },
              { "type": "number", "exclusiveMinimum": 0 },
              { "type": "number", "exclusiveMinimum": 0 }
            ]
          },
          "origin": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": { "type": "number", "minimum": 0 }
          },
          "requiredLayerIds": { "$ref": "#/$defs/idArray" },
          "elementIds": { "$ref": "#/$defs/idArray" }
        }
      }
    }
  }
}
