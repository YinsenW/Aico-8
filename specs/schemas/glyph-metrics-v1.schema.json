{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/glyph-metrics-v1.schema.json",
  "title": "Aico 8 deterministic glyph metrics v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "fontAssetId", "fontSha256", "unitsPerEm", "ascent", "descent", "lineGap", "coverageCodePoints", "glyphs"],
  "properties": {
    "schemaVersion": { "const": "aico8.glyph-metrics.v1" },
    "fontAssetId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$" },
    "fontSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "unitsPerEm": { "type": "number", "exclusiveMinimum": 0 },
    "ascent": { "type": "number" },
    "descent": { "type": "number" },
    "lineGap": { "type": "number" },
    "coverageCodePoints": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0, "maximum": 1114111, "not": { "minimum": 55296, "maximum": 57343 } }
    },
    "glyphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["codePoint", "glyphId", "advanceWidth", "bbox"],
        "properties": {
          "codePoint": { "type": "integer", "minimum": 0, "maximum": 1114111, "not": { "minimum": 55296, "maximum": 57343 } },
          "glyphId": { "type": "integer", "minimum": 0 },
          "advanceWidth": { "type": "number", "minimum": 0 },
          "bbox": {
            "type": "object",
            "additionalProperties": false,
            "required": ["minX", "minY", "maxX", "maxY"],
            "properties": {
              "minX": { "type": "number" }, "minY": { "type": "number" },
              "maxX": { "type": "number" }, "maxY": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
