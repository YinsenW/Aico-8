{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/cart-input-v1.schema.json",
  "title": "Aico 8 cart input v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "inputId", "format", "source", "provenance"],
  "properties": {
    "schemaVersion": { "const": "aico8.cart-input.v1" },
    "inputId": { "$ref": "#/$defs/id" },
    "format": { "$ref": "#/$defs/format" },
    "source": { "$ref": "#/$defs/file" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suppliedBy", "intendedUse", "sourceUrl", "declaredLicense", "releasePermission"],
      "properties": {
        "suppliedBy": { "type": "string", "minLength": 1 },
        "intendedUse": { "enum": ["private-research", "public-synthetic-fixture", "publication"] },
        "sourceUrl": { "type": ["string", "null"], "pattern": "^https://" },
        "declaredLicense": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spdx", "evidence"],
          "properties": {
            "spdx": { "$ref": "#/$defs/spdx" },
            "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/file" } }
          }
        },
        "releasePermission": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "evidence"],
          "properties": {
            "status": { "$ref": "#/$defs/permission" },
            "evidence": { "type": "array", "items": { "$ref": "#/$defs/file" } }
          },
          "allOf": [
            {
              "if": { "properties": { "status": { "const": "granted" } }, "required": ["status"] },
              "then": { "properties": { "evidence": { "type": "array", "minItems": 1 } } }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "intendedUse": { "enum": ["public-synthetic-fixture", "publication"] } }, "required": ["intendedUse"] },
          "then": { "properties": { "releasePermission": { "type": "object", "properties": { "status": { "const": "granted" } }, "required": ["status"] } } }
        }
      ]
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "spdx": { "type": "string", "pattern": "^(?:[A-Za-z0-9][A-Za-z0-9.+-]*|NOASSERTION)$" },
    "format": { "enum": ["p8-text", "p8-png", "raw-rom"] },
    "permission": { "enum": ["granted", "denied", "unknown"] },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byteLength"],
      "properties": {
        "path": { "$ref": "#/$defs/safePath" },
        "sha256": { "$ref": "#/$defs/hash" },
        "byteLength": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
