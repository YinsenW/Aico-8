{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/text-run-v1.schema.json",
  "title": "Aico 8 decoded semantic text run v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "sequence", "update", "classification", "reasonMask",
    "sideEffectMask", "unsupportedMask", "anchor", "cursorIn", "cursorOut",
    "rightmostX", "diagnosticBounds", "foregroundIn", "foregroundOut",
    "printAttributes", "customFont", "appendNewline", "spans", "rawP8scii"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sequence": { "$ref": "#/$defs/u32" },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "high"],
      "properties": {
        "low": { "$ref": "#/$defs/u32" },
        "high": { "$ref": "#/$defs/u32" }
      }
    },
    "classification": {
      "enum": ["safe-modern", "reference-only", "review-required"]
    },
    "reasonMask": { "$ref": "#/$defs/u32" },
    "sideEffectMask": { "$ref": "#/$defs/u32" },
    "unsupportedMask": { "$ref": "#/$defs/u32" },
    "anchor": { "$ref": "#/$defs/point" },
    "cursorIn": { "$ref": "#/$defs/point" },
    "cursorOut": { "$ref": "#/$defs/point" },
    "rightmostX": { "$ref": "#/$defs/i32" },
    "diagnosticBounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "$ref": "#/$defs/i32" },
        "y": { "$ref": "#/$defs/i32" },
        "width": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
        "height": { "type": "integer", "minimum": 0, "maximum": 2147483647 }
      }
    },
    "foregroundIn": { "type": "integer", "minimum": 0, "maximum": 15 },
    "foregroundOut": { "type": "integer", "minimum": 0, "maximum": 15 },
    "printAttributes": { "$ref": "#/$defs/u32" },
    "customFont": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision", "memoryBase", "memorySize"],
      "properties": {
        "revision": { "$ref": "#/$defs/u32" },
        "memoryBase": { "const": 22016 },
        "memorySize": { "const": 256 }
      }
    },
    "appendNewline": { "type": "boolean" },
    "spans": {
      "type": "array",
      "items": { "$ref": "#/$defs/span" }
    },
    "rawP8scii": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
    }
  },
  "$defs": {
    "u32": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
    "i32": { "type": "integer", "minimum": -2147483648, "maximum": 2147483647 },
    "point": {
      "type": "array",
      "prefixItems": [{ "$ref": "#/$defs/i32" }, { "$ref": "#/$defs/i32" }],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["byteOffset", "byteLength", "kind", "reasonMask", "sideEffectMask"],
      "properties": {
        "byteOffset": { "$ref": "#/$defs/u32" },
        "byteLength": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "kind": { "enum": ["visual", "control", "inline-glyph", "terminator"] },
        "reasonMask": { "$ref": "#/$defs/u32" },
        "sideEffectMask": { "$ref": "#/$defs/u32" }
      }
    }
  }
}
