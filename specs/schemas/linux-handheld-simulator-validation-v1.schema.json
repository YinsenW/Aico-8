{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/linux-handheld-simulator-validation-v1.schema.json",
  "title": "Aico 8 Linux handheld simulator validation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "capturedAt", "subject", "simulator", "automatedChecks", "artifacts", "status"],
  "properties": {
    "schemaVersion": { "const": "aico8.linux-handheld-simulator-validation.v1" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["webReleaseTreeSha256", "assetManifestSha256", "targetProfileId", "targetProfileSha256", "entryModuleSha256"],
      "properties": {
        "webReleaseTreeSha256": { "$ref": "#/$defs/sha256" },
        "assetManifestSha256": { "$ref": "#/$defs/sha256" },
        "targetProfileId": { "$ref": "#/$defs/id" },
        "targetProfileSha256": { "$ref": "#/$defs/sha256" },
        "entryModuleSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "simulator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "environmentClass", "osName", "osVersion", "kernelVersion", "architecture", "sessionType", "viewport", "browser", "graphicsRenderer", "controllerFixture"],
      "properties": {
        "profileId": { "$ref": "#/$defs/id" },
        "environmentClass": { "const": "linux-chromium-square-simulator" },
        "osName": { "type": "string", "minLength": 1 },
        "osVersion": { "type": "string", "minLength": 1 },
        "kernelVersion": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "sessionType": { "const": "x11" },
        "viewport": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": { "width": { "const": 1024 }, "height": { "const": 1024 } }
        },
        "browser": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "engine"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "engine": { "const": "Blink" }
          }
        },
        "graphicsRenderer": { "type": "string", "minLength": 1 },
        "controllerFixture": { "const": "pre-navigation-standard-gamepad" }
      }
    },
    "automatedChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "freshBrowserProfile", "exactWebArtifact", "squareViewport", "offlineReload",
        "serviceWorkerControlled", "persistentStorageRoundTrip", "simulatedControllerInputPassed",
        "fullscreenApiAvailable", "audioGraphAvailable", "lifecycleFreezeResumePassed",
        "wasmAvailable", "webgl2Available", "readyScreenshotCaptured", "coldLaunchMilliseconds", "performance"
      ],
      "properties": {
        "freshBrowserProfile": { "type": "boolean" },
        "exactWebArtifact": { "type": "boolean" },
        "squareViewport": { "type": "boolean" },
        "offlineReload": { "type": "boolean" },
        "serviceWorkerControlled": { "type": "boolean" },
        "persistentStorageRoundTrip": { "type": "boolean" },
        "simulatedControllerInputPassed": { "type": "boolean" },
        "fullscreenApiAvailable": { "type": "boolean" },
        "audioGraphAvailable": { "type": "boolean" },
        "lifecycleFreezeResumePassed": { "type": "boolean" },
        "wasmAvailable": { "type": "boolean" },
        "webgl2Available": { "type": "boolean" },
        "readyScreenshotCaptured": { "type": "boolean" },
        "coldLaunchMilliseconds": { "type": "number", "minimum": 0 },
        "performance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "captureSeconds", "warmupFrames", "requiredSampleFrames", "observedSampleFrames",
            "droppedFrameThresholdMilliseconds", "startupMillisecondsMax", "p95FrameMillisecondsMax",
            "droppedFrameRatioMax", "p95FrameMilliseconds", "droppedFrameRatio", "budgetPassed"
          ],
          "properties": {
            "captureSeconds": { "type": "number", "minimum": 60 },
            "warmupFrames": { "type": "integer", "minimum": 0 },
            "requiredSampleFrames": { "type": "integer", "minimum": 1 },
            "observedSampleFrames": { "type": "integer", "minimum": 0 },
            "droppedFrameThresholdMilliseconds": { "type": "number", "exclusiveMinimum": 0 },
            "startupMillisecondsMax": { "type": "number", "exclusiveMinimum": 0 },
            "p95FrameMillisecondsMax": { "type": "number", "exclusiveMinimum": 0 },
            "droppedFrameRatioMax": { "type": "number", "minimum": 0, "maximum": 1 },
            "p95FrameMilliseconds": { "type": "number", "minimum": 0 },
            "droppedFrameRatio": { "type": "number", "minimum": 0, "maximum": 1 },
            "budgetPassed": { "type": "boolean" }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screenshotSha256", "capabilityReportSha256", "offlineReportSha256", "storageReportSha256", "controllerReportSha256", "lifecycleReportSha256", "performanceReportSha256"],
      "properties": {
        "screenshotSha256": { "$ref": "#/$defs/sha256" },
        "capabilityReportSha256": { "$ref": "#/$defs/sha256" },
        "offlineReportSha256": { "$ref": "#/$defs/sha256" },
        "storageReportSha256": { "$ref": "#/$defs/sha256" },
        "controllerReportSha256": { "$ref": "#/$defs/sha256" },
        "lifecycleReportSha256": { "$ref": "#/$defs/sha256" },
        "performanceReportSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "status": { "enum": ["passed", "failed"] }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
  }
}
