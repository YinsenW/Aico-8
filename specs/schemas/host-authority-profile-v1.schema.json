{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/host-authority-profile-v1.schema.json",
  "title": "Aico 8 trusted human authority host profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId", "hostId", "signingKey", "reviewerKeyIds", "agentCapabilities", "persistence"],
  "properties": {
    "schemaVersion": { "const": "aico8.host-authority-profile.v1" },
    "profileId": { "$ref": "#/$defs/id" },
    "hostId": { "$ref": "#/$defs/id" },
    "signingKey": {
      "type": "object", "additionalProperties": false,
      "required": ["keyId", "publicKeySpkiBase64", "publicKeySha256"],
      "properties": { "keyId": { "$ref": "#/$defs/id" }, "publicKeySpkiBase64": { "type": "string", "minLength": 40 }, "publicKeySha256": { "$ref": "#/$defs/hash" } }
    },
    "reviewerKeyIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "agentCapabilities": {
      "type": "object", "additionalProperties": false,
      "required": ["mayRegister", "mayDecide", "maySign", "mayWriteHead"],
      "properties": { "mayRegister": { "const": false }, "mayDecide": { "const": false }, "maySign": { "const": false }, "mayWriteHead": { "const": false } }
    },
    "persistence": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "externalRollbackAnchor"],
      "properties": { "mode": { "const": "transactional-monotonic-head" }, "externalRollbackAnchor": { "const": "required" } }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
