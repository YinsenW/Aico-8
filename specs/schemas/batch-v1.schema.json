{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/batch-v1.schema.json",
  "title": "Aico 8 isolated batch v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "status", "policy", "games"],
  "properties": {
    "schemaVersion": { "const": "aico8.batch.v1" },
    "batchId": { "$ref": "#/$defs/id" },
    "status": { "enum": ["queued", "running", "partial", "complete", "failed"] },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxParallel", "failureIsolation", "acceptanceRequiresEvidence"],
      "properties": {
        "maxParallel": { "type": "integer", "minimum": 1, "maximum": 8 },
        "failureIsolation": { "const": true },
        "acceptanceRequiresEvidence": { "const": true }
      }
    },
    "games": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/game" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonicalReplaySha256": { "$ref": "#/$defs/hash" },
        "hdReviewDecisionSha256": { "$ref": "#/$defs/hash" },
        "webPackageSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameId", "cartSha256", "workspaceId", "priority", "state", "stage", "attempt", "evidence"],
      "properties": {
        "gameId": { "$ref": "#/$defs/id" },
        "cartSha256": { "$ref": "#/$defs/hash" },
        "workspaceId": { "$ref": "#/$defs/id" },
        "priority": { "type": "integer", "minimum": 1 },
        "state": { "enum": ["queued", "running", "blocked", "failed", "accepted"] },
        "stage": { "enum": ["ingest", "compatibility", "gameplay", "hd-review", "web-package", "accepted"] },
        "attempt": { "type": "integer", "minimum": 1 },
        "failureClass": { "$ref": "#/$defs/id" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    }
  }
}
