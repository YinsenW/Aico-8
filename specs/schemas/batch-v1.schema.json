{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/batch-v1.schema.json",
  "title": "Aico 8 isolated batch v1",
  "$comment": "JSON Schema owns structural validation. The TypeScript validator additionally owns property-level uniqueness across games, deterministic workspace identity, derived batch status, attempt sequencing and budget relationships, latest-result equality, evidence equality, and maxParallel running-count enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "batchId", "status", "policy", "games"],
  "properties": {
    "schemaVersion": { "const": "aico8.batch.v1" },
    "batchId": { "$ref": "#/$defs/id" },
    "status": { "enum": ["queued", "running", "partial", "complete", "failed"] },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxParallel", "maxAttempts", "attemptTimeoutMs", "failureIsolation", "acceptanceRequiresEvidence"],
      "properties": {
        "maxParallel": { "type": "integer", "minimum": 1, "maximum": 8 },
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 8 },
        "attemptTimeoutMs": { "type": "integer", "minimum": 100, "maximum": 86400000 },
        "failureIsolation": { "const": true },
        "acceptanceRequiresEvidence": { "const": true }
      }
    },
    "games": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/game" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonicalReplaySha256": { "$ref": "#/$defs/hash" },
        "hdReviewDecisionSha256": { "$ref": "#/$defs/hash" },
        "webPackageSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "completeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalReplaySha256", "hdReviewDecisionSha256", "webPackageSha256"],
      "properties": {
        "canonicalReplaySha256": { "$ref": "#/$defs/hash" },
        "hdReviewDecisionSha256": { "$ref": "#/$defs/hash" },
        "webPackageSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "authorizedInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cartPath", "rightsProfile"],
      "properties": {
        "cartPath": {
          "type": "string",
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
        },
        "rightsProfile": { "$ref": "#/$defs/id" }
      }
    },
    "requestedTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "targetProfileId", "targetProfileSha256"],
      "properties": {
        "product": { "const": "standalone-web" },
        "targetProfileId": { "$ref": "#/$defs/id" },
        "targetProfileSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "attemptResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "outcome", "stage", "evidence"],
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "outcome": { "enum": ["blocked", "failed", "accepted"] },
        "stage": { "enum": ["ingest", "compatibility", "gameplay", "hd-review", "web-package", "accepted"] },
        "moduleId": { "$ref": "#/$defs/id" },
        "failureClass": { "$ref": "#/$defs/id" },
        "evidence": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": { "properties": { "outcome": { "const": "accepted" } }, "required": ["outcome"] },
          "then": {
            "required": ["moduleId"],
            "properties": {
              "stage": { "const": "accepted" },
              "evidence": { "$ref": "#/$defs/completeEvidence" }
            },
            "not": { "required": ["failureClass"] }
          },
          "else": {
            "required": ["failureClass"],
            "not": { "anyOf": [{ "required": ["moduleId"] }, { "properties": { "stage": { "const": "accepted" } }, "required": ["stage"] }] }
          }
        }
      ]
    },
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameId", "cartSha256", "input", "request", "workspaceId", "priority", "state", "stage", "attempt", "attempts", "evidence"],
      "properties": {
        "gameId": { "$ref": "#/$defs/id" },
        "cartSha256": { "$ref": "#/$defs/hash" },
        "input": { "$ref": "#/$defs/authorizedInput" },
        "request": { "$ref": "#/$defs/requestedTarget" },
        "workspaceId": { "$ref": "#/$defs/id" },
        "priority": { "type": "integer", "minimum": 1 },
        "state": { "enum": ["queued", "running", "blocked", "failed", "accepted"] },
        "stage": { "enum": ["ingest", "compatibility", "gameplay", "hd-review", "web-package", "accepted"] },
        "attempt": { "type": "integer", "minimum": 0 },
        "attempts": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/attemptResult" } },
        "failureClass": { "$ref": "#/$defs/id" },
        "evidence": { "$ref": "#/$defs/evidence" }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "accepted" } }, "required": ["state"] },
          "then": {
            "properties": {
              "stage": { "const": "accepted" },
              "attempts": { "type": "array", "minItems": 1 },
              "evidence": { "$ref": "#/$defs/completeEvidence" }
            },
            "not": { "required": ["failureClass"] }
          }
        },
        {
          "if": { "properties": { "state": { "enum": ["blocked", "failed"] } }, "required": ["state"] },
          "then": {
            "required": ["failureClass"],
            "not": { "properties": { "stage": { "const": "accepted" } }, "required": ["stage"] }
          }
        },
        {
          "if": { "properties": { "state": { "enum": ["queued", "running"] } }, "required": ["state"] },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["failureClass"] },
                { "properties": { "stage": { "const": "accepted" } }, "required": ["stage"] }
              ]
            }
          }
        }
      ]
    }
  }
}
