{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/game-module-v1.schema.json",
  "title": "Aico 8 internal game module v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "moduleId", "status", "metadata", "payload", "mappings", "save", "provenance", "runtime", "validation"],
  "properties": {
    "schemaVersion": { "const": "aico8.game-module.v1" },
    "moduleId": { "$ref": "#/$defs/id" },
    "status": { "enum": ["draft", "validated"] },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "author"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rom", "sourceCode", "presentationModule"],
      "properties": {
        "rom": { "$ref": "#/$defs/file" },
        "sourceCode": { "$ref": "#/$defs/file" },
        "presentationModule": { "$ref": "#/$defs/file" }
      }
    },
    "mappings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hdIdentityMap", "assetPack", "typographyManifest", "audioManifest"],
      "properties": {
        "hdIdentityMap": { "$ref": "#/$defs/file" },
        "assetPack": { "$ref": "#/$defs/file" },
        "typographyManifest": { "$ref": "#/$defs/file" },
        "audioManifest": { "$ref": "#/$defs/file" }
      }
    },
    "save": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "persistentBytes", "resetCompatibilityStateOnActivate"],
      "properties": {
        "namespace": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*:aico8\\.game-module\\.v1$" },
        "persistentBytes": { "type": "integer", "minimum": 0, "maximum": 256 },
        "resetCompatibilityStateOnActivate": { "const": true }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceCartSha256", "workspaceManifestSha256", "rightsProfile"],
      "properties": {
        "sourceCartSha256": { "$ref": "#/$defs/hash" },
        "workspaceManifestSha256": { "$ref": "#/$defs/hash" },
        "rightsProfile": { "$ref": "#/$defs/id" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dependencies", "targetBindings"],
      "properties": {
        "dependencies": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/dependency" } },
        "targetBindings": { "type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/webTargetBinding" } }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence"],
      "properties": {
        "status": { "enum": ["pending", "passed"] },
        "evidence": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/evidence" } }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "draft" } }, "required": ["status"] },
      "then": {
        "properties": {
          "validation": {
            "type": "object",
            "properties": { "status": { "const": "pending" }, "evidence": { "type": "array", "maxItems": 0 } }
          }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "validated" } }, "required": ["status"] },
      "then": {
        "properties": {
          "validation": {
            "type": "object",
            "properties": {
              "status": { "const": "passed" },
              "evidence": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "allOf": [
                  { "contains": { "type": "object", "properties": { "kind": { "const": "canonical-replay" } }, "required": ["kind"] }, "minContains": 1, "maxContains": 1 },
                  { "contains": { "type": "object", "properties": { "kind": { "const": "hd-review-decision" } }, "required": ["kind"] }, "minContains": 1, "maxContains": 1 }
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*//)[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/safePath" },
        "sha256": { "$ref": "#/$defs/hash" }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "manifestSha256"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "$ref": "#/$defs/version" },
        "manifestSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "webTargetBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "targetProfileId", "targetProfileSha256"],
      "properties": {
        "target": { "const": "web-pwa" },
        "targetProfileId": { "$ref": "#/$defs/id" },
        "targetProfileSha256": { "$ref": "#/$defs/hash" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": { "enum": ["canonical-replay", "hd-review-decision"] },
        "path": { "$ref": "#/$defs/safePath" },
        "sha256": { "$ref": "#/$defs/hash" }
      }
    }
  }
}
