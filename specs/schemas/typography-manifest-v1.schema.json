{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aico8.dev/schemas/typography-manifest-v1.schema.json",
  "title": "Aico 8 typography manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestId", "osFallback", "assets", "roles"],
  "properties": {
    "schemaVersion": { "const": "aico8.typography-manifest.v1" },
    "manifestId": { "$ref": "#/$defs/id" },
    "osFallback": { "const": false },
    "assets": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/asset" } },
    "roles": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/role" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*//).+$" },
    "codePoints": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 1114111,
        "not": { "minimum": 55296, "maximum": 57343 }
      },
      "uniqueItems": true
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "family", "version", "face", "file", "metrics", "source", "license", "coverageCodePoints"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "family": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "face": {
          "type": "object",
          "additionalProperties": false,
          "required": ["weight", "style"],
          "properties": {
            "weight": { "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900] },
            "style": { "enum": ["normal", "italic"] }
          }
        },
        "file": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "format"],
          "properties": {
            "path": { "$ref": "#/$defs/path" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "format": { "enum": ["woff2", "msdf-atlas", "sdf-atlas"] }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256", "schemaVersion"],
          "properties": {
            "path": { "$ref": "#/$defs/path" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "schemaVersion": { "const": "aico8.glyph-metrics.v1" }
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["upstreamRevision", "provenancePath", "provenanceSha256"],
          "properties": {
            "upstreamRevision": { "type": "string", "minLength": 1 },
            "provenancePath": { "$ref": "#/$defs/path" },
            "provenanceSha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spdx", "evidencePath", "evidenceSha256"],
          "properties": {
            "spdx": { "type": "string", "minLength": 1 },
            "evidencePath": { "$ref": "#/$defs/path" },
            "evidenceSha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "coverageCodePoints": { "$ref": "#/$defs/codePoints", "minItems": 1 }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "renderer", "fontAssetIds", "requiredCodePoints", "metrics", "fit", "osFallback"],
      "properties": {
        "role": { "enum": ["display", "menu", "dialogue", "hud-number", "symbol", "diagnostic", "localized-body"] },
        "renderer": { "enum": ["woff2-canvas", "msdf", "sdf"] },
        "fontAssetIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
        "requiredCodePoints": { "$ref": "#/$defs/codePoints" },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sizePx", "weight", "trackingPx", "lineHeightPx"],
          "properties": {
            "sizePx": { "type": "number", "exclusiveMinimum": 0 },
            "weight": { "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900] },
            "trackingPx": { "type": "number" },
            "lineHeightPx": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "fit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minSizePx", "overflow", "maxLines"],
          "properties": {
            "minSizePx": { "type": "number", "exclusiveMinimum": 0 },
            "overflow": { "enum": ["wrap", "ellipsis", "fail"] },
            "maxLines": { "type": "integer", "minimum": 1 }
          }
        },
        "osFallback": { "const": false }
      }
    }
  }
}
