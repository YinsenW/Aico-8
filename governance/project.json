    "graphics_semantics_interpretation": "docs/reference/pico8-graphics-semantics.md"
  },
  "glossary": [
    { "id": "TERM-COMPAT-STATE", "term": "compatibility state", "definition": "Authoritative PICO-8 VM, memory, timing, input, persistence, raster, and audio state." },
    { "id": "TERM-HD-PRESENTATION", "term": "HD presentation", "definition": "Replaceable 1024 visual layer that cannot mutate compatibility state." },
    { "id": "TERM-REQUIREMENT", "term": "requirement", "definition": "Stable product outcome whose wording is owned by the PRD." },
    { "id": "TERM-EXIT", "term": "exit", "definition": "Binary acceptance condition attached to exactly one requirement." },
    { "id": "TERM-EVIDENCE", "term": "evidence", "definition": "Durable artifact supporting an exit; implementation alone is insufficient." },
    { "id": "TERM-SELECTOR", "term": "test selector", "definition": "Stable command identifier that validates named exits." },
    { "id": "TERM-JOB", "term": "Job", "definition": "Versioned non-interactive pipeline operation with declared inputs and outputs." },
    { "id": "TERM-RIGHTS", "term": "rights gate", "definition": "Independent permission and attribution decision required for publication." },
    { "id": "TERM-SKILL", "term": "Skill", "definition": "Late thin orchestration layer over proven Jobs and contracts." },
    { "id": "TERM-GAME-MODULE", "term": "internal game module", "definition": "Versioned private build input for one validated remake; not a promised public cartridge format." },
    { "id": "TERM-FIXED-COLLECTION", "term": "fixed collection", "definition": "Standalone product that statically binds several independently validated game modules and isolated saves." },
    { "id": "TERM-BATCH-MANIFEST", "term": "batch manifest", "definition": "Immutable declaration that fans multiple authorized carts into isolated Job graphs and acceptance records." },
    { "id": "TERM-WORK-PACKAGE", "term": "work package", "definition": "Stable roadmap unit that defines dependency-bounded tasks and acceptance Exit links without owning status." },
    { "id": "TERM-TEXT-RUN", "term": "semantic text run", "definition": "Ordered presentation record that preserves original P8SCII bytes, compatibility metrics, state, side-effect boundaries, and fallback classification." },
    { "id": "TERM-TYPOGRAPHY-MANIFEST", "term": "typography manifest", "definition": "Versioned mapping from semantic text roles to bundled font assets, layout, coverage, licensing, and fallback policy." }
  ],
