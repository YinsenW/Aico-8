{
  "$schema": "./schema.json",
  "schema_version": 1,
  "quality_gate": {
    "minimum_dimension_score": 9.5,
    "dimensions": [
      "navigation_lifecycle",
      "cross_document_consistency",
      "traceability_acceptance",
      "development_support",
      "lean_maintainability"
    ]
  },
  "navigation": [
    { "id": "DOC-AGENT-ENTRY", "path": "AGENTS.md", "role": "agent entry and safety rules", "max_lines": 160 },
    { "id": "DOC-GOVERNANCE", "path": "docs/GOVERNANCE.md", "role": "ownership, lifecycle, and score policy", "max_lines": 250 },
    { "id": "DOC-PRODUCT", "path": "docs/PRODUCT.md", "role": "product intent and requirement wording", "max_lines": 250 },
    { "id": "DOC-ARCHITECTURE", "path": "docs/ARCHITECTURE.md", "role": "system and language boundaries", "max_lines": 250 },
    { "id": "DOC-CONTRACTS", "path": "docs/CONTRACTS.md", "role": "API, Job, and data relationships", "max_lines": 250 },
    { "id": "DOC-DEVELOPMENT", "path": "docs/DEVELOPMENT.md", "role": "implementation, recovery, tests, and handoff", "max_lines": 250 },
    { "id": "DOC-STATUS", "path": "governance/project.json", "role": "current focus, status, exits, evidence, selectors, and open work", "max_lines": 700 }
  ],
  "resource_classes": [
    {
      "class": "authoritative_current",
      "locations": ["AGENTS.md", "README.md", "ROADMAP.md", "docs/", "specs/", "governance/"],
      "policy": "Update with the owning change; status exists only in governance/project.json."
    },
    {
      "class": "decision_history",
      "locations": ["docs/decisions/"],
      "policy": "Accepted ADRs are append-only and are superseded by a new ADR."
    },
    {
      "class": "maintained_reference",
      "locations": ["docs/reference/"],
      "policy": "Read only when linked by a contract or exit; primary sources remain authoritative."
    },
    {
      "class": "research_evidence",
      "locations": ["research/"],
      "policy": "Preserve observations and supersession notices; never use as current status."
    },
    {
      "class": "executable_generated_evidence",
      "locations": ["tests/", "research/*.json", "CI logs"],
      "policy": "Run or regenerate from declared inputs; do not hand-edit generated evidence."
    },
    {
      "class": "private_input",
      "locations": ["private/", "pico8_carts/", "workspaces/"],
      "policy": "Local and non-publishable until the rights gate is verified."
    }
  ],
  "concept_owners": {
    "product_intent": "docs/PRODUCT.md",
    "current_status": "governance/project.json",
    "governance_policy": "docs/GOVERNANCE.md",
    "system_architecture": "docs/ARCHITECTURE.md",
    "language_boundary": "docs/decisions/0001-language-boundary.md",
