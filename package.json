{
  "name": "aico-8",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "build:private-web": "node scripts/build-private-web.mjs",
    "check": "pnpm --recursive --if-present check",
    "test": "pnpm --recursive --if-present test",
    "verify": "pnpm verify:governance && pnpm verify:public && make -C runtime/core test && make -C runtime/core wasm-test && pnpm verify:web",
    "verify:governance": "node scripts/verify-governance.mjs",
    "verify:public": "node scripts/verify-public-repository.mjs",
    "verify:hd-identity": "pnpm --filter @aico8/contracts exec vitest run src/hd-identity-map.test.ts",
    "verify:hd-presentation": "pnpm --filter @aico8/contracts exec vitest run src/hd-presentation-audit.test.ts",
    "verify:replay": "pnpm --filter @aico8/contracts exec vitest run src/replay.test.ts",
    "verify:private-remake": "node scripts/validate-private-remake.mjs",
    "verify:qualification-private": "make -C runtime/core wasm && node scripts/validate-private-qualification.mjs",
    "verify:web-package": "node scripts/verify-web-package.mjs",
    "verify:web": "pnpm check && pnpm test && pnpm build"
  }
}
